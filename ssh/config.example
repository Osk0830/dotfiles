# ~/.ssh/config のテンプレート
#
# ローカルにコピーして使用:
# cp ssh/config.example ~/.ssh/config
#
# 注意:
# 実際のホスト名、ユーザー名、秘密鍵パスはこのファイルにコミットしないこと

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
  AddKeysToAgent yes
  UseKeychain yes

# 任意の接続先テンプレート
# Host my-server
#   HostName example.com
#   User deploy
#   Port 22
#   IdentityFile ~/.ssh/id_ed25519_my_server
#   AddKeysToAgent yes
#   UseKeychain yes
