# Docker Desktop is intentionally NOT managed by Homebrew.
#
# Do not add the following entries:
#   brew "docker"
#   brew "docker-compose"
#   cask "docker"
#
# Install Docker Desktop manually from the official installer.
# Docker Desktop provides the docker CLI and Docker Compose plugin.
# See: mac/docker.md
